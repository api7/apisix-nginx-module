+int
+ngx_stream_lua_ffi_socket_tcp_get_read_any_result(ngx_stream_lua_request_t *r,
+    ngx_stream_lua_socket_tcp_upstream_t *u, u_char **buf, size_t len,
+    size_t *actual_len, u_char *errbuf, size_t *errbuf_size)
+{
+    ngx_log_debug0(NGX_LOG_DEBUG_STREAM, r->connection->log, 0,
+                   "lua tcp socket get receive any result");
+
+    if (u->read_waiting) {
+        return NGX_AGAIN;
+    }
+
+    /* Restore req_socket_rev_handler before evaluating the result.
+     * This ensures that any SSL posted_next_events arriving between
+     * co_yield() resumption and this call are properly dispatched
+     * instead of being consumed by block_reading.
+     * See: read-any-ssl-block-investigation.md section 6.2 */
+    if (u->raw_downstream || u->body_downstream) {
+#if (NGX_DEBUG)
+        {
+        ngx_event_t     *rev = r->connection->read;
+        ngx_log_debug3(NGX_LOG_DEBUG_STREAM, r->connection->log, 0,
+                       "read_any get_result restore rev_handler: "
+                       "rev_active:%d rev_ready:%d rev_timer_set:%d",
+                       (int) rev->active, (int) rev->ready,
+                       (int) rev->timer_set);
+        }
 #endif
+        r->read_event_handler = ngx_stream_lua_req_socket_rev_handler;
+    }
+
+    return ngx_stream_lua_ffi_socket_read_retval_handler_any(r, u, buf, len,
+                                                             actual_len,
+                                                             errbuf, errbuf_size);
+}
