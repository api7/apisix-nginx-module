+/* Composite SSL read handler for xRPC dual-coroutine model.
+ *
+ * When from_upstream writes to a raw_downstream SSL connection and
+ * SSL_write() returns SSL_ERROR_WANT_READ, nginx replaces
+ * c->read->handler with ngx_ssl_read_handler (which forwards read
+ * events to the write handler).  This hijacks the read event chain
+ * so that to_upstream's read_any timer expiry never reaches
+ * socket_read_handler, causing the read coroutine to stall until
+ * the upstream times out (typically 60s).
+ *
+ * This composite handler fixes the problem:
+ * - For timer events: dispatch to the original stream-lua handler
+ *   so read_any timeout / retry logic works correctly.
+ * - For non-timer events (actual data arrival): first let SSL
+ *   complete its renegotiation/key-update via the write handler,
+ *   then also call the original handler so stream-lua can process
+ *   any data that became available.
+ *
+ * See: docs/tech/protocols/read-any-ssl-block-investigation.md §8-9
+ */
+static void
+ngx_stream_lua_xrpc_composite_ssl_read_handler(ngx_event_t *rev)
+{
+    ngx_connection_t  *c;
+
+    c = rev->data;
+
+    ngx_log_debug3(NGX_LOG_DEBUG_STREAM, c->log, 0,
+                   "xrpc composite ssl read handler, "
+                   "timedout:%d ready:%d saved_handler:%p",
+                   (int) rev->timedout, (int) rev->ready,
+                   c->ssl ? c->ssl->saved_read_handler : NULL);
+
+    if (rev->timedout) {
+        /* Timer event (e.g. read_any 1000ms timeout).
+         * The SSL layer does not need this; route it to stream-lua
+         * so socket_read_handler can process the timeout. */
+
+        if (c->ssl && c->ssl->saved_read_handler) {
+            ngx_event_handler_pt  orig = c->ssl->saved_read_handler;
+
+            /* Restore before calling to avoid re-entrance issues */
+            c->ssl->saved_read_handler = NULL;
+            rev->handler = orig;
+
+            ngx_log_debug0(NGX_LOG_DEBUG_STREAM, c->log, 0,
+                           "xrpc composite ssl: timer event, "
+                           "restored original handler, dispatching");
+
+            orig(rev);
+            return;
+        }
+
+        /* Fallback: saved_read_handler already cleared (SSL write
+         * completed between our installation and the timer firing).
+         * Nothing more to do; the handler has been restored by
+         * ngx_ssl_write's success path already. */
+        return;
+    }
+
+    /* Non-timer event: actual data arrived on the connection.
+     * Let SSL finish its renegotiation / key-update first. */
+    c->write->handler(c->write);
+
+    /* After the SSL write handler runs, check if SSL_write succeeded
+     * and already restored saved_read_handler (meaning our composite
+     * handler was replaced).  If so, also invoke the original handler
+     * for the read event so stream-lua processes any available data. */
+
+    if (c->ssl == NULL || c->ssl->saved_read_handler == NULL) {
+        /* SSL write completed; saved_read_handler was restored by
+         * ngx_ssl_write's success path.  The original handler is now
+         * in rev->handler.  Call it for any pending read data. */
+        if (rev->handler != ngx_stream_lua_xrpc_composite_ssl_read_handler) {
+            ngx_log_debug0(NGX_LOG_DEBUG_STREAM, c->log, 0,
+                           "xrpc composite ssl: ssl write done, "
+                           "calling restored original handler");
+            rev->handler(rev);
+        }
+        return;
+    }
+
+    /* SSL write still pending (WANT_READ again).  Our composite handler
+     * stays installed.  Nothing else to do this round. */
+    ngx_log_debug0(NGX_LOG_DEBUG_STREAM, c->log, 0,
+                   "xrpc composite ssl: ssl write still pending");
+}
+
+
+int
+ngx_stream_lua_ffi_socket_tcp_send_from_socket(ngx_stream_lua_request_t *r,
+    ngx_stream_lua_socket_tcp_upstream_t *u, ngx_stream_lua_socket_tcp_upstream_t *src,
+    u_char *errbuf, size_t *errbuf_size)
+{
+    size_t                               len = 0;
+    ngx_int_t                            rc;
+    ngx_chain_t                         *cl, *in_cl;
+    ngx_stream_lua_ctx_t                *ctx;
+    int                                  tcp_nodelay;
+    ngx_buf_t                           *b;
+    ngx_connection_t                    *c;
+    ngx_stream_lua_loc_conf_t           *llcf;
+    ngx_stream_core_srv_conf_t          *clcf;
+    ngx_stream_lua_co_ctx_t             *coctx;
+    ngx_event_handler_pt                 saved_rev_handler;
+
+    if (u == NULL || u->peer.connection == NULL || u->write_closed) {
+        llcf = ngx_stream_lua_get_module_loc_conf(r, ngx_stream_lua_module);
+
+        if (llcf->log_socket_errors) {
+            ngx_log_error(NGX_LOG_ERR, r->connection->log, 0,
+                          "attempt to send data on a closed socket: u:%p, "
+                          "c:%p, ft:%d eof:%d",
+                          u, u ? u->peer.connection : NULL,
+                          u ? (int) u->ft_type : 0, u ? (int) u->eof : 0);
+        }
+
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size, "closed") - errbuf;
+        return NGX_ERROR;
+    }
+
+    if (u->request != r) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size, "bad request")
+                       - errbuf;
+        return NGX_DONE;
+    }
+
+    ngx_stream_lua_ffi_socket_check_busy_connecting(r, u, errbuf, errbuf_size);
+    ngx_stream_lua_ffi_socket_check_busy_writing(r, u, errbuf, errbuf_size);
+
+    if (u->body_downstream) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size,
+                                    "attempt to write to request sockets")
+                       - errbuf;
+        return NGX_DONE;
+    }
+
+    ngx_log_debug1(NGX_LOG_DEBUG_STREAM, r->connection->log, 0,
+                   "lua tcp socket send timeout: %M", u->send_timeout);
+
+    ctx = ngx_stream_lua_get_module_ctx(r, ngx_stream_lua_module);
+
+    for (in_cl = src->bufs_in; in_cl; in_cl = in_cl->next) {
+        b = in_cl->buf;
+
+        len += b->last - b->pos;
+
+        ngx_log_debug3(NGX_LOG_DEBUG_STREAM, r->connection->log, 0,
+                       "lua tcp socket move cl:%p buf %p, len: %d",
+                       in_cl, b, b->last - b->pos);
+
+    }
+
+    ngx_log_debug2(NGX_LOG_DEBUG_STREAM, r->connection->log, 0,
+                   "lua tcp socket move total buf %p, len: %d",
+                   src->bufs_in, len);
+
+    if (len == 0) {
+        return NGX_OK;
+    }
+
+    cl = ngx_stream_lua_chain_get_free_buf(r->connection->log, r->pool,
+                                           &ctx->free_bufs, len);
+
+    if (cl == NULL) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size, "no memory") - errbuf;
+        return NGX_DONE;
+    }
+
+    if (!src->bufs_in->next) {
+        cl->buf->pos = src->bufs_in->buf->pos;
+        cl->buf->last = src->bufs_in->buf->last;
+
+    } else {
+        /* TODO: avoid copying (it requires to modify the way cosocket sends data) */
+        for (in_cl = src->bufs_in; in_cl; in_cl = in_cl->next) {
+            b = in_cl->buf;
+            cl->buf->last = ngx_copy(cl->buf->last, b->pos, b->last - b->pos);
+        }
+    }
+
+    ngx_stream_lua_ffi_socket_reset_buf(ctx, src);
+
+    u->request_bufs = cl;
+
+    u->request_len = len;
+
+    /* mimic ngx_stream_upstream_init_request here */
+
+    clcf = ngx_stream_lua_get_module_loc_conf(r, ngx_stream_core_module);
+    c = u->peer.connection;
+
+    if (clcf->tcp_nodelay && c->tcp_nodelay == NGX_TCP_NODELAY_UNSET) {
+        ngx_log_debug0(NGX_LOG_DEBUG_STREAM, c->log, 0,
+                       "lua socket tcp_nodelay");
+
+        tcp_nodelay = 1;
+
+        if (setsockopt(c->fd, IPPROTO_TCP, TCP_NODELAY,
+                       (const void *) &tcp_nodelay, sizeof(int))
+            == -1)
+        {
+            llcf = ngx_stream_lua_get_module_loc_conf(r, ngx_stream_lua_module);
+            if (llcf->log_socket_errors) {
+                ngx_connection_error(c, ngx_socket_errno,
+                                     "setsockopt(TCP_NODELAY) "
+                                     "failed");
+            }
+
+            *errbuf_size = ngx_snprintf(errbuf, *errbuf_size,
+                                        "setsocketopt tcp_nodelay failed")
+                           - errbuf;
+            return NGX_ERROR;
+        }
+
+        c->tcp_nodelay = NGX_TCP_NODELAY_SET;
+    }
+
+    u->write_waiting = 0;
+    u->write_co_ctx = NULL;
+
+    ngx_stream_lua_probe_socket_tcp_send_start(r, u, b->pos, len);
+
+    /* Save the downstream read handler before SSL_write may hijack it.
+     * When writing to a raw_downstream SSL connection, SSL_write() may
+     * return SSL_ERROR_WANT_READ (e.g. during TLS 1.3 key update),
+     * which causes nginx to replace c->read->handler with
+     * ngx_ssl_read_handler.  This breaks the xRPC dual-coroutine
+     * model because timer events for to_upstream's read_any will be
+     * routed to the write path instead of stream-lua's read path.
+     *
+     * Detection strategy: compare c->read->handler before and after
+     * ngx_stream_lua_socket_send().  We cannot rely on
+     * c->ssl->saved_read_handler because ngx_ssl_write()'s success
+     * path restores the handler and clears saved_read_handler before
+     * returning to us (blind spot).
+     *
+     * See: read-any-ssl-block-investigation.md §8-10 */
+    saved_rev_handler = NULL;
+    if (u->raw_downstream && c->ssl) {
+        saved_rev_handler = c->read->handler;
+    }
+
+    rc = ngx_stream_lua_socket_send(r, u);
+
+    dd("socket send returned %d", (int) rc);
+
+    /* Check if SSL_write hijacked c->read->handler.
+     *
+     * Case 1: ngx_ssl_write returned WANT_READ and the for-loop broke
+     *   → c->read->handler is ngx_ssl_read_handler (hijacked)
+     *   → c->ssl->saved_read_handler holds the original
+     *   → We install composite handler and keep saved_read_handler
+     *
+     * Case 2: ngx_ssl_write hit WANT_READ then succeeded in a later
+     *   iteration of the for-loop (or a subsequent SSL_write call)
+     *   → ngx_ssl_write success path restored c->read->handler and
+     *     cleared saved_read_handler, then posted c->read
+     *   → c->read->handler == saved_rev_handler (already restored)
+     *   → No action needed, but the posted c->read event will trigger
+     *     socket_read_handler which may interact with timer
+     *
+     * We detect case 1 by comparing handler addresses directly,
+     * which works even if saved_read_handler was transiently set
+     * and cleared within the same call chain.
+     */
+    if (saved_rev_handler && c->read->handler != saved_rev_handler) {
+
+        if (c->ssl && c->ssl->saved_read_handler) {
+            /* Case 1: handler still hijacked, saved_read_handler valid */
+            ngx_log_error(NGX_LOG_WARN, c->log, 0,
+                          "xrpc: SSL_write hijacked read handler during "
+                          "send_from_socket, installing composite handler; "
+                          "original=%p current=%p ssl_saved=%p",
+                          saved_rev_handler, c->read->handler,
+                          c->ssl->saved_read_handler);
+
+            c->read->handler =
+                ngx_stream_lua_xrpc_composite_ssl_read_handler;
+
+        } else {
+            /* Handler changed but saved_read_handler is NULL.
+             * This can happen if SSL_write internally restored the
+             * handler to a different value, or if a third-party module
+             * changed it.  Restore our original handler to be safe. */
+            ngx_log_error(NGX_LOG_WARN, c->log, 0,
+                          "xrpc: read handler changed during "
+                          "send_from_socket but saved_read_handler is NULL; "
+                          "restoring original; original=%p current=%p",
+                          saved_rev_handler, c->read->handler);
+
+            c->read->handler = saved_rev_handler;
+        }
+    }
+
+    if (rc == NGX_ERROR) {
+        ngx_stream_lua_ffi_socket_write_error_retval_handler(r, u, errbuf,
+                                                             errbuf_size);
+        return NGX_ERROR;
+    }
+
+    if (rc == NGX_OK) {
+        return rc;
+    }
+
+    /* rc == NGX_AGAIN */
+
+    coctx = ctx->cur_co_ctx;
+
+    ngx_stream_lua_cleanup_pending_operation(coctx);
+    coctx->cleanup = ngx_stream_lua_coctx_cleanup;
+    coctx->data = u;
+
+    if (u->raw_downstream) {
+        ctx->writing_raw_req_socket = 1;
+    }
+
+    if (ctx->entered_content_phase) {
+        r->write_event_handler = ngx_stream_lua_content_wev_handler;
+
+    } else {
+        r->write_event_handler = ngx_stream_lua_core_run_phases;
+    }
+
+    u->write_co_ctx = coctx;
+    u->write_waiting = 1;
+    u->write_prepare_retvals = ngx_stream_lua_socket_tcp_dummy_retval_handler;
+
+    dd("setting data to %p", u);
+
+    ngx_log_debug1(NGX_LOG_DEBUG_STREAM, c->log, 0,
+                   "lua socket send yield, u: %p", u);
+
+    return NGX_AGAIN;
+}
+
+
+int
+ngx_stream_lua_ffi_socket_tcp_get_send_result(ngx_stream_lua_request_t *r,
+    ngx_stream_lua_socket_tcp_upstream_t *u, u_char *errbuf,
+    size_t *errbuf_size)
+{
+    ngx_log_debug0(NGX_LOG_DEBUG_STREAM, r->connection->log, 0,
+                   "lua tcp socket get send result");
+
+    if (u->ft_type) {
+        ngx_stream_lua_ffi_socket_write_error_retval_handler(r, u, errbuf,
+                                                             errbuf_size);
+        return NGX_ERROR;
+    }
+
     return NGX_OK;
 }
 
