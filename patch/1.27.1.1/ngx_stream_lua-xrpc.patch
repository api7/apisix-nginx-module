+int
+ngx_stream_lua_ffi_socket_tcp_getsockname(ngx_stream_lua_request_t *r,
+    ngx_stream_lua_socket_tcp_upstream_t *u, u_char *buf, size_t *buf_len,
+    unsigned short *port, u_char *errbuf, size_t *errbuf_size)
+{
+    ngx_connection_t    *c;
+    ngx_sockaddr_t       sa;
+    socklen_t            len;
+    size_t               n;
+
+    if (u == NULL || u->peer.connection == NULL) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size, "closed") - errbuf;
+        return NGX_ERROR;
+    }
+
+    if (u->request != r) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size, "bad request")
+                       - errbuf;
+        return NGX_DONE;
+    }
+
+    c = u->peer.connection;
+    if (c->fd == (ngx_socket_t) -1) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size, "closed") - errbuf;
+        return NGX_ERROR;
+    }
+
+    len = sizeof(sa);
+    if (getsockname(c->fd, &sa.sockaddr, &len) == -1) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size,
+                                    "getsockname() failed") - errbuf;
+        return NGX_ERROR;
+    }
+
+    n = ngx_sock_ntop(&sa.sockaddr, len, buf, *buf_len, 0);
+    if (n == 0) {
+        *errbuf_size = ngx_snprintf(errbuf, *errbuf_size,
+                                    "failed to format addr") - errbuf;
+        return NGX_ERROR;
+    }
+
+    *buf_len = n;
+    if (port) {
+        *port = ngx_inet_get_port(&sa.sockaddr);
+    }
+
+    return NGX_OK;
+}
