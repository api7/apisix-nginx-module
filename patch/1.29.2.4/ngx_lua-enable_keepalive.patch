+static void
+ngx_http_lua_balancer_get_keepalive_pool(lua_State *L, ngx_str_t *cpool_name,
+    ngx_http_lua_balancer_keepalive_pool_t **cpool)
+{
+    ngx_http_lua_balancer_keepalive_pool_t      *upool;
+
